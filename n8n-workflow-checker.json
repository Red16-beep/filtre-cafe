{
  "name": "filtré · Vérificateur Liens",
  "nodes": [
    {
      "id": "b2c3d4e5-0002-0002-0002-000000000001",
      "name": "Chaque Lundi 9h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "weeks",
              "triggerAtDay": [1],
              "triggerAtHour": 9,
              "triggerAtMinute": 0
            }
          ]
        }
      }
    },
    {
      "id": "b2c3d4e5-0002-0002-0002-000000000002",
      "name": "Lire cafés actifs",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "operation": "search",
        "base": {
          "__rl": true,
          "value": "REMPLACER_PAR_TON_BASE_ID",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "Cafés",
          "mode": "name"
        },
        "filterByFormula": "{Status} = 'active'",
        "options": {}
      },
      "credentials": {
        "airtableTokenApi": {
          "id": "REMPLACER_PAR_TON_CREDENTIAL_ID",
          "name": "Airtable"
        }
      }
    },
    {
      "id": "b2c3d4e5-0002-0002-0002-000000000003",
      "name": "Vérifier chaque lien",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4",
      "position": [680, 300],
      "parameters": {
        "method": "GET",
        "url": "={{ $json.fields.URL }}",
        "options": {
          "timeout": 10000,
          "redirect": { "redirect": { "followRedirects": true, "maxRedirects": 5 } },
          "response": { "response": { "fullResponse": true } }
        }
      }
    },
    {
      "id": "b2c3d4e5-0002-0002-0002-000000000004",
      "name": "Lien mort ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "leftValue": "={{ $json.statusCode }}",
              "rightValue": 400,
              "operator": { "type": "number", "operation": "gte" }
            }
          ],
          "combinator": "or"
        }
      }
    },
    {
      "id": "b2c3d4e5-0002-0002-0002-000000000005",
      "name": "Marquer inactif dans Airtable",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [1120, 200],
      "parameters": {
        "operation": "update",
        "base": {
          "__rl": true,
          "value": "REMPLACER_PAR_TON_BASE_ID",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "Cafés",
          "mode": "name"
        },
        "id": "={{ $('Lire cafés actifs').item.json.id }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Status": "inactive"
          }
        }
      },
      "credentials": {
        "airtableTokenApi": {
          "id": "REMPLACER_PAR_TON_CREDENTIAL_ID",
          "name": "Airtable"
        }
      }
    },
    {
      "id": "b2c3d4e5-0002-0002-0002-000000000006",
      "name": "Envoyer email alerte",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [1120, 420],
      "parameters": {
        "toEmail": "REMPLACER_PAR_TON_EMAIL",
        "subject": "🚨 filtré. · Lien mort détecté",
        "emailType": "html",
        "message": "<h2>Un lien est mort sur filtré.</h2><p><strong>Café :</strong> {{ $('Lire cafés actifs').item.json.fields.Nom }}</p><p><strong>Marque :</strong> {{ $('Lire cafés actifs').item.json.fields.Marque }}</p><p><strong>URL :</strong> {{ $('Lire cafés actifs').item.json.fields.URL }}</p><p><strong>Code HTTP :</strong> {{ $json.statusCode }}</p><p>Le café a été automatiquement marqué <em>inactif</em> dans Airtable et retiré du catalogue.</p><p>Va sur Airtable pour mettre à jour l'URL ou supprimer l'entrée.</p>",
        "options": {}
      },
      "credentials": {
        "smtp": {
          "id": "REMPLACER_PAR_TON_CREDENTIAL_SMTP",
          "name": "SMTP"
        }
      }
    }
  ],
  "connections": {
    "Chaque Lundi 9h": {
      "main": [[{ "node": "Lire cafés actifs", "type": "main", "index": 0 }]]
    },
    "Lire cafés actifs": {
      "main": [[{ "node": "Vérifier chaque lien", "type": "main", "index": 0 }]]
    },
    "Vérifier chaque lien": {
      "main": [[{ "node": "Lien mort ?", "type": "main", "index": 0 }]]
    },
    "Lien mort ?": {
      "main": [
        [{ "node": "Marquer inactif dans Airtable", "type": "main", "index": 0 }],
        []
      ]
    },
    "Marquer inactif dans Airtable": {
      "main": [[{ "node": "Envoyer email alerte", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "filtré" }]
}
