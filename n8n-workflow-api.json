    "Lire Airtable": {
      "main": [[{ "node": "Formater pour le site", "type": "main", "index": 0 }]]
    },
    "Formater pour le site": {
      "main": [[{ "node": "Répondre au site", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "filtré" }]
}
